# Server (Render sets PORT automatically — do not hardcode in code)
PORT=3000
NODE_ENV=development

# OpenAI — never commit real keys; set only in .env or host dashboard
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Public API URL (optional)
# Leave empty when Express serves frontend + API on the same host (recommended).
# Set to https://your-api.onrender.com when frontend is hosted separately (e.g. Vercel).
PUBLIC_API_BASE=

# CORS — comma-separated allowed origins (required for split frontend/backend deploy)
# Same-origin single deploy: http://localhost:3000 is enough
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=30

# SQLite path (use persistent disk on Render, e.g. /var/data/study.db)
DATABASE_PATH=./data/study.db
